# Forensic Agent API Configuration Template
# Copy this content to a file named .env in Part2/Agent/

# --- OpenAI Configuration ---
# Your OpenAI API Key (starts with sk-...)
OPENAI_API_KEY=your_openai_key_here

# The model to use for reasoning (e.g., gpt-4o, gpt-4-turbo)
OPENAI_MODEL=gpt-4o

# Optional: OpenAI-compatible API base (e.g. Commonstack)
# OPENAI_BASE_URL=https://api.commonstack.ai/v1

# --- Gemini Configuration ---
# Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_key_here

# The Gemini model to use (e.g., gemini-1.5-pro, gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-pro

# --- Agent Settings ---
# Maximum number of autonomous steps the agent can take
MAX_AGENT_STEPS=6
